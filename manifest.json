    "settings": {
      "route": "/settings/plugins/youtube-player"
    }
  },
  "renderer": {
    "source": "renderer/YouTubePluginPage.jsx",
    "entry": "renderer/index.js"
  },
  "main": {
    "entry": "main/index.mjs"
  }
}
