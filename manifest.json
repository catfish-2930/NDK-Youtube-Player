{
  "id": "youtube-player",
  "name": "NDK-YouTube Player",
  "version": "0.1.0",
  "description": "Online multimedia player",
  "type": "Multimedia",
  "github": "https://github.com/catfish-2930/NDK-Youtube-Player",
  "enabledByDefault": true,
  "entryPoints": {
    "home": {
      "label": "YouTube",
      "route": "/plugins/youtube-player",
